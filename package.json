{
  "name": "ratchet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --sort build",
    "dev": "pnpm -r --parallel --filter @ratchet/core --filter @ratchet/cli dev",
    "typecheck": "pnpm -r --sort typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "vitest run --config vitest.eval.config.ts",
    "eval:live": "vitest run --config vitest.live-eval.config.ts",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^26.0.0",
    "dotenv": "^17.4.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
